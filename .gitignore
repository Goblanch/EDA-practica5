# ============================================================
#  C++ & CLion — .gitignore
# ============================================================

# ------------------------------------------------------------
# CLion / JetBrains IDE
# ------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
cmake-build-*/
.idea_modules/

# ------------------------------------------------------------
# CMake
# ------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps/
build/
out/

# ------------------------------------------------------------
# Compiled object files
# ------------------------------------------------------------
*.o
*.obj
*.lo
*.slo
*.ko

# ------------------------------------------------------------
# Precompiled headers
# ------------------------------------------------------------
*.gch
*.pch

# ------------------------------------------------------------
# Compiled dynamic libraries
# ------------------------------------------------------------
*.so
*.so.*
*.dylib
*.dll

# ------------------------------------------------------------
# Compiled static libraries
# ------------------------------------------------------------
*.a
*.la
*.lai
*.lib

# ------------------------------------------------------------
# Executables
# ------------------------------------------------------------
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# ------------------------------------------------------------
# Debug / profiling artifacts
# ------------------------------------------------------------
*.dSYM/
*.su
*.idb
*.pdb
*.ilk
*.map
gmon.out
callgrind.out.*
cachegrind.out.*
massif.out.*

# ------------------------------------------------------------
# Conan (package manager)
# ------------------------------------------------------------
conanbuildinfo.*
conaninfo.txt
.conan/
conan.lock

# ------------------------------------------------------------
# vcpkg (package manager)
# ------------------------------------------------------------
vcpkg_installed/

# ------------------------------------------------------------
# Coverage & testing
# ------------------------------------------------------------
*.gcno
*.gcda
*.gcov
coverage/
lcov.info

# ------------------------------------------------------------
# Logs & temp files
# ------------------------------------------------------------
*.log
*.tmp
*.temp
*.swp
*.swo
*~

# ------------------------------------------------------------
# OS-generated files
# ------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.fuse_hidden*
.directory
.Trash-*
